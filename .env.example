# =========================================================
# N-One Stock Analysis Agent — Environment Variables
# Sao chép file này thành .env và điền giá trị thực
# KHÔNG commit file .env vào git
# =========================================================

# --- Bắt buộc ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Dữ liệu thị trường (tùy chọn, nâng cao) ---
# TCBS_API_KEY=...          # Nếu dùng nguồn TCBS thay vì VCI
# SSI_API_KEY=...           # Nếu dùng SSI data feed

# --- Thị trường ---
RISK_FREE_RATE=0.048        # Lợi suất TP Chính phủ VN 10Y — cập nhật hàng quý

# --- App ---
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
CACHE_DIR=.cache
OUTPUT_DIR=reports
