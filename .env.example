# HTTP port the server listens on (AgentBase expects 8080)
PORT=8080

# OpenAI-compatible vision LLM credentials
# GreenNode AI Platform: get a key via the /agentbase-llm skill
LLM_API_KEY=
LLM_BASE_URL=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1
LLM_MODEL=gpt-4o

# Language used for the generated report text (e.g. "vi", "en")
REPORT_LANGUAGE=vi
